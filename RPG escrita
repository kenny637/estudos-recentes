def key_pressed():
    """Verifica se alguma tecla foi pressionada (não bloqueante)."""
    if sys.platform == 'win32':
        import msvcrt
        return msvcrt.kbhit()
    else:
        dr, _, _ = select.select([sys.stdin], [], [], 0)
        return dr != []

def clear_key():
    """Limpa o buffer de teclas, descartando qualquer tecla pressionada."""
    if sys.platform == 'win32':
        import msvcrt
        while msvcrt.kbhit():
            msvcrt.getch()
    else:
        old_settings = termios.tcgetattr(sys.stdin)
        try:
            tty.setraw(sys.stdin.fileno())
            while select.select([sys.stdin], [], [], 0)[0]:
                sys.stdin.read(1)
        finally:
            termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)

def print_with_skip(text, delay=0.02):
    """Imprime texto caractere por caractere. Pressione qualquer tecla para pular o restante."""
    for i, ch in enumerate(text):
        print(ch, end='', flush=True)
        if key_pressed():
            print(text[i+1:], end='', flush=True)
            clear_key()
            break
        time.sleep(delay)
    print()


